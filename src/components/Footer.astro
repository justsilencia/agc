---
const contactEmail = 'steadfast@agcbjj.com';
---

<footer class="site-footer" id="contact">
	<div class="footer-brand">
		<a class="brand" href="/" aria-label="Appalachian Grappling Collective home">
			<span class="brand-mark">
				<img src="/logo-1.png" alt="" />
			</span>
			<span class="brand-name">Appalachian<br />Grappling<br />Collective</span>
		</a>
		<div class="social-links" aria-label="Social links">
			<a href="/facebook" aria-label="Facebook group coming soon">
				<svg viewBox="0 0 24 24" aria-hidden="true">
					<path
						d="M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07c0 6.03 4.39 11.03 10.13 11.93v-8.44H7.08v-3.49h3.05V9.41c0-3.03 1.79-4.7 4.53-4.7 1.31 0 2.68.24 2.68.24v2.96h-1.51c-1.49 0-1.96.93-1.96 1.89v2.27h3.33l-.53 3.49h-2.8V24C19.61 23.1 24 18.1 24 12.07Z"
					></path>
				</svg>
				<span>Facebook Group</span>
			</a>
		</div>
	</div>
	<div class="footer-links">
		<h2>Resources</h2>
		<a href="/rules-etiquette">Rules &amp; Etiquette</a>
		<a href="/our-values">Values</a>
		<a href="/apply">Apply</a>
		<a href="/faq">FAQ</a>
		<a href="/waiver">Waiver</a>
	</div>
	<address class="footer-contact">
		<h2>Contact</h2>
		<a href="">123 Jujitsu Way<br />Dandridge, TN 37725</a>
		<em>(Actual address given upon approval)</em>
		<a href={`mailto:${contactEmail}`}>{contactEmail}</a>
	</address>
	<p class="copyright">
		© <span data-current-year>2026</span> Appalachian Grappling Collective. All rights reserved.
	</p>
</footer>

<script>
	const year = document.querySelector('[data-current-year]');

	if (year) {
		year.textContent = String(new Date().getFullYear());
	}
</script>
